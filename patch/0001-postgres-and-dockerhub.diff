++	}
++	if update.NonUniqueName != nil {
++		merged.NonUniqueName = update.NonUniqueName
++	}
++	if update.Deleted != nil {
++		merged.Deleted = update.Deleted
++	}
++	if update.Folder != nil {
++		merged.Folder = update.Folder
++	}
