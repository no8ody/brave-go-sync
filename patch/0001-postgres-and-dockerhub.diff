++	mtime BIGINT NOT NULL,
++	folder BOOLEAN NOT NULL DEFAULT FALSE,
++	client_defined_unique_tag TEXT,
++	server_defined_unique_tag TEXT,
++	deleted BOOLEAN NOT NULL DEFAULT FALSE,
